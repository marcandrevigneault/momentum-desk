# momentum-desk environment template. Copy to .env for local use, or set these
# as Fly secrets (`fly secrets set KEY=value`). .env is gitignored — never commit
# real credentials.

# --- Dashboard auth (public deploy) ---
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=change-me

# --- IBKR Client Portal (bravos-style phone-push login) ---
# USERNAME/PASSWORD are consumed by ibeam (the gateway auto-login) — the app code
# never reads the password. The only manual step at login is approving the IBKR
# Mobile push (IB Key 2FA) on your phone.
IBKR_USERNAME=your_ib_username
IBKR_PASSWORD=your_ib_password
IBKR_PAPER=true                              # true = paper account, false = live
IBKR_ENABLED=true                            # run the gateway + in-process keepalive
IBKR_GATEWAY_URL=https://localhost:5000/v1/api
IBKR_ACCOUNT_ID=                             # blank = first account the gateway reports

# --- Optional data feed (separate from execution) ---
POLYGON_API_KEY=
DATA_FEED=mock                               # mock | polygon
MODE=paper                                   # paper | live
